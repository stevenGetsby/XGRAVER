{
    "models": {
        "denoiser": {
            "name": "DirectMaskModel",
            "args": {
                "resolution": 4,
                "model_channels": 768,
                "cond_channels": 1024,
                "num_blocks": 12,
                "num_heads": 12,
                "mlp_ratio": 4,
                "pe_mode": "rope",
                "attn_mode": "windowed",
                "window_size": 32,
                "use_fp16": true,
                "qk_rms_norm": true,
                "qk_rms_norm_cross": true,
                "use_checkpoint": false,
                "head_type": "dense_query_conv",
                "dense_query_channels": 32,
                "dense_query_layers": 3,
                "dense_query_grid_size": 64,
                "dense_query_skip_linear": true,
                "dense_query_train_only": true
            }
        }
    },
    "dataset": {
        "name": "ImageConditionedBlockMask",
        "args": {
            "roots": [
                "/mnt/data/yizhao/TRAIN",
                "/cfs/yizhao/SKET"
            ],
            "max_block_num": 13500,
            "min_aesthetic_score": 0.0,
            "max_samples": 15000,
            "mask_resolution": 4
        }
    },
    "test_dataset": {
        "name": "ImageConditionedBlockMask",
        "args": {
            "roots": [
                "/mnt/data/yizhao/TRAIN",
                "/cfs/yizhao/SKET"
            ],
            "max_block_num": 13500,
            "min_aesthetic_score": 0.0,
            "max_samples": 15000,
            "mask_resolution": 4
        }
    },
    "trainer": {
        "name": "ImageConditionedDirectMaskTrainer",
        "args": {
            "max_steps": 80000,
            "batch_size_per_gpu": 4,
            "batch_split": 1,
            "recall_weight": 1.5,
            "dice_weight": 1.0,
            "surface_threshold": 0.5,
            "snapshot_render_normals": false,
            "optimizer": {
                "name": "AdamW",
                "args": {
                    "lr": 5e-4,
                    "weight_decay": 0,
                    "betas": [0.9, 0.95]
                }
            },
            "ema_rate": [0.999],
            "grad_clip": {
                "name": "AdaptiveGradClipper",
                "args": {
                    "max_norm": 2.0,
                    "clip_percentile": 99
                }
            },
            "i_log": 200,
            "i_print": 10,
            "num_samples": 128,
            "i_sample": 1000,
            "i_save": 10000,
            "image_cond_model": "dinov2_vitl14_reg"
        }
    }
}

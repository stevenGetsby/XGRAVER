{
    "models": {
        "denoiser": {
            "name": "DirectMaskModel",
            "args": {
                "resolution": 8,
                "model_channels": 768,
                "cond_channels": 1024,
                "num_blocks": 12,
                "num_heads": 12,
                "mlp_ratio": 4,
                "pe_mode": "rope",
                "attn_mode": "windowed",
                "window_size": 32,
                "use_fp16": true,
                "qk_rms_norm": true,
                "qk_rms_norm_cross": true,
                "use_checkpoint": false
            }
        }
    },
    "dataset": {
        "name": "ImageConditionedBlockMask",
        "args": {
            "roots": [
                "/mnt/data/yizhao/TRAIN"
            ],
            "max_block_num": 7000,
            "min_aesthetic_score": 0.0,
            "max_samples": 100
        }
    },
    "test_dataset": {
        "name": "ImageConditionedBlockMask",
        "args": {
            "roots": [
                "/mnt/data/yizhao/TRAIN"
            ],
            "max_block_num": 7000,
            "min_aesthetic_score": 0.0,
            "max_samples": 100
        }
    },
    "trainer": {
        "name": "ImageConditionedDirectMaskTrainer",
        "args": {
            "max_steps": 100,
            "batch_size_per_gpu": 2,
            "batch_split": 1,
            "recall_weight": 1.5,
            "surface_threshold": 0.5,
            "optimizer": {
                "name": "AdamW",
                "args": {
                    "lr": 2e-4,
                    "weight_decay": 0,
                    "betas": [0.9, 0.95]
                }
            },
            "ema_rate": [0.999],
            "grad_clip": 1.0,
            "i_log": 50,
            "i_print": 10,
            "num_samples": 4,
            "i_sample": 50,
            "i_save": 10000,
            "image_cond_model": "dinov2_vitl14_reg"
        }
    }
}

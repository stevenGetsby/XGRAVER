{
    "models": {
        "denoiser": {
            "name": "SparseFlowModel",
            "args": {
                "resolution": 0,
                "bottleneck_dim": 128,
                "submask_resolution": 0,
                "model_channels": 768,
                "cond_channels": 1024,
                "num_blocks": 12,
                "num_pooled_layers": 4,
                "num_heads": 12,
                "mlp_ratio": 4,
                "pe_mode": "rope",
                "attn_mode": "windowed",
                "window_size": 32,
                "use_fp16": true,
                "qk_rms_norm": true,
                "qk_rms_norm_cross": true,
                "use_checkpoint": false,
                "num_context_registers": 32,
                "context_start_block": 0
            }
        }
    },
    "dataset": {
        "name": "ImageConditionedCascadedBlockFeats",
        "args": {
            "roots": [
                "/cfs/yizhao/TRAIN"
            ],
            "max_block_num": 12000,
            "min_aesthetic_score": 0.0,
            "max_samples": 0,
            "require_pred_mask": false
        }
    },
    "test_dataset": {
        "name": "ImageConditionedCascadedBlockFeats",
        "args": {
            "roots": [
                "/cfs/yizhao/TRAIN"
            ],
            "max_block_num": 12000,
            "min_aesthetic_score": 0.0,
            "max_samples": 100,
            "require_pred_mask": false
        }
    },
    "trainer": {
        "name": "ImageConditionedCascadedFeatsCFGTrainer",
        "args": {
            "max_steps": 100000,
            "batch_size_per_gpu": 2,
            "batch_split": 1,
            "noise_scale": 1.0,
            "loss_type": "v_loss",
            "lambda_normal": 0.05,
            "surface_weight": 8.0,
            "complexity_boost": 2.0,
            "cond_noise_std": 0.0,
            "cascade_dilate_kernel": 3,
            "cascade_dilate_iters": 2,
            "gt_clip_max": 0.5,
            "t_schedule": {
                "name": "logitNormal",
                "args": {
                    "mean": -0.8,
                    "std": 0.8
                }
            },
            "optimizer": {
                "name": "AdamW",
                "args": {
                    "lr": 0.0001,
                    "weight_decay": 0,
                    "betas": [0.9, 0.95]
                }
            },
            "ema_rate": [0.9999],
            "grad_clip": {
                "name": "AdaptiveGradClipper",
                "args": {
                    "max_norm": 4.0,
                    "clip_percentile": 95
                }
            },
            "i_log": 200,
            "i_print": 10,
            "num_samples": 16,
            "i_sample": 2500,
            "i_save": 5000,
            "image_cond_model": "dinov2_vitl14_reg"
        }
    }
}

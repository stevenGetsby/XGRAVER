{
    "models": {
        "denoiser": {
            "name": "SparseFlowModel",
            "args": {
                "resolution": 8,
                "bottleneck_dim": 0,
                "submask_resolution": 0,
                "model_channels": 768,
                "cond_channels": 1024,
                "num_blocks": 8,
                "num_heads": 12,
                "mlp_ratio": 4,
                "pe_mode": "rope",
                "attn_mode": "windowed",
                "window_size": 32,
                "use_fp16": true,
                "qk_rms_norm": true,
                "qk_rms_norm_cross": true,
                "use_checkpoint": true
            }
        }
    },
    "dataset": {
        "name": "ImageConditionedBlockSubmask",
        "args": {
            "roots": [
                "/mnt/data/yizhao/TRAIN"
            ],
            "max_block_num": 15000,
            "min_aesthetic_score": 0.0,
            "max_samples": 0
        }
    },
    "test_dataset": {
        "name": "ImageConditionedBlockSubmask",
        "args": {
            "roots": [
                "/mnt/data/yizhao/TRAIN"
            ],
            "max_block_num": 15000,
            "min_aesthetic_score": 0.0,
            "max_samples": 0
        }
    },
    "trainer": {
        "name": "ImageConditionedSparseMaskFlowCFGTrainer",
        "args": {
            "max_steps": 100000,
            "batch_size_per_gpu": 4,
            "batch_split": 1,
            "noise_scale": 1.0,
            "t_schedule": {
                "name": "logitNormal",
                "args": {
                    "mean": -0.8,
                    "std": 0.8
                }
            },
            "optimizer": {
                "name": "AdamW",
                "args": {
                    "lr": 2e-4,
                    "weight_decay": 0,
                    "betas": [0.9, 0.95]
                }
            },
            "ema_rate": [0.999],
            "grad_clip": {
                "name": "AdaptiveGradClipper",
                "args": {
                    "max_norm": 2.0,
                    "clip_percentile": 99
                }
            },
            "i_log": 200,
            "i_print": 10,
            "num_samples": 16,
            "i_sample": 5000,
            "i_save": 10000,
            "image_cond_model": "dinov2_vitl14_reg"
        }
    }
}

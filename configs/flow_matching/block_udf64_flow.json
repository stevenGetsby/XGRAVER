{
    "models": {
        "denoiser": {
            "name": "SparseFlowModel",
            "args": {
                "resolution": 4,
                "model_channels": 768,
                "cond_channels": 1024,
                "num_blocks": 12,
                "num_heads": 12,
                "mlp_ratio": 4,
                "pe_mode": "rope",
                "attn_mode": "windowed",
                "window_size": 32,
                "use_fp16": true,
                "qk_rms_norm": true,
                "qk_rms_norm_cross": true,
                "use_checkpoint": false
            }
        }
    },
    "dataset": {
        "name": "ImageConditionedBlockUDF64",
        "args": {
            "roots": [
                "/cfs/yizhao/TRAIN",
                "/cfs/yizhao/SKET"
            ],
            "max_block_num": 13500,
            "min_aesthetic_score": 0.0,
            "max_samples": 10000
        }
    },
    "test_dataset": {
        "name": "ImageConditionedBlockUDF64",
        "args": {
            "roots": [
                "/cfs/yizhao/TRAIN",
                "/cfs/yizhao/SKET"
            ],
            "max_block_num": 13500,
            "min_aesthetic_score": 0.0,
            "max_samples": 10000
        }
    },
    "trainer": {
        "name": "ImageConditionedUDF64FlowTrainer",
        "args": {
            "max_steps": 100000,
            "batch_size_per_gpu": 4,
            "batch_split": 1,
            "surface_weight": 4.0,
            "noise_scale": 1.0,
            "mask_threshold": 0.5,
            "optimizer": {
                "name": "AdamW",
                "args": {
                    "lr": 2e-4,
                    "weight_decay": 0,
                    "betas": [0.9, 0.95]
                }
            },
            "ema_rate": [0.999],
            "grad_clip": {
                "name": "AdaptiveGradClipper",
                "args": {
                    "max_norm": 2.0,
                    "clip_percentile": 99
                }
            },
            "i_log": 200,
            "i_print": 10,
            "num_samples": 32,
            "i_sample": 5000,
            "i_save": 10000,
            "image_cond_model": "dinov2_vitl14_reg"
        }
    }
}
